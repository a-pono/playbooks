# Database credentials
# Copy to .env in project root: cp assets/.env.example .env
# Fill in real values. Use single quotes for passwords: PG_PASSWORD='my$ecret!pass'
# Load before any query: source .env && <cli-command>
# NEVER read .env directly - use env vars in commands

# PostgreSQL (ecommerce)
PG_HOST=
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=ecommerce

# ClickHouse (analytics)
CH_HOST=
CH_PORT=9000
CH_USER=
CH_PASSWORD=
CH_DATABASE=analytics
